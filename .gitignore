## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/
.vscode/
*.user
*.suo
*.cache
*.ilk
*.meta
*.guid

# MSTest test results
[TestResult]/
*.trx
*.log
*.nunit

# NUnit
*.XmlReport

# Visual C++ cache files
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.ilk
*.meta

# NuGet Packages
*.nupkg
*.snupkg
**/packages/
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json
artifacts/

# Others
sql/
*.dbmdl
*.dbproj
*.jfm
*.sdf
*.dd
*.ldf
*.rdl
*.rdlc
*.ssrs
*.ssrs.designer.cs

# Mac
.DS_Store
